# AutoPMF environment variables — add to Vercel dashboard
FEEDBACK_SECRET=your-secret-token-here
DEPLOY_URL=https://finsyt-platform.vercel.app
ANTHROPIC_API_KEY=sk-ant-...
BLOB_READ_WRITE_TOKEN=   # auto-set by: vercel blob create-store feedback --access private

# Earnings-call audio source (see docs/transcript-audio.md).
# Leave unset to ship transcripts with silent timed playback (no demo audio).
# When set, the API streams ${TRANSCRIPT_AUDIO_BASE_URL}/{SYMBOL}_{YEAR}_Q{QUARTER}.mp3
TRANSCRIPT_AUDIO_BASE_URL=
