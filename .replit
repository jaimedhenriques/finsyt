CORS_ALLOWED_ORIGINS = "https://finsyt.replit.app"
DB_RUNTIME_ROLE = "app_runtime"
PLATFORM_PRODUCTION_DEMO = "1"
ALLOW_DEMO_IDENTITY = "1"

